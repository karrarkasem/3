rules_version = '2';

// ══════════════════════════════════════════════════════
//  🏛️ BABIL PLATFORM — Firestore Security Rules
//  المبدأ: كل مستأجر يقرأ/يكتب بياناته الخاصة فقط
//  request.auth.uid == tenantId (Firebase Auth UID)
// ══════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── بيانات المستأجر الرئيسية ──
    match /tenants/{tenantId} {

      // قراءة وكتابة للمستأجر صاحب الحساب فقط
      allow read:   if request.auth != null && request.auth.uid == tenantId;
      allow create: if request.auth != null && request.auth.uid == tenantId;
      allow update: if request.auth != null && request.auth.uid == tenantId;
      allow delete: if false; // لا يُحذف من الكود — فقط من Firebase Console

      // ── المنتجات ──
      match /products/{productId} {
        allow read, write: if request.auth != null && request.auth.uid == tenantId;
      }

      // ── الطلبات ──
      match /orders/{orderId} {
        // المستأجر يقرأ ويعدّل كل الطلبات
        allow read, write: if request.auth != null && request.auth.uid == tenantId;

        // العملاء يستطيعون إنشاء طلب جديد بدون تسجيل دخول (كاشتراك عام)
        // مع التحقق أن tenantId في الوثيقة صحيح
        allow create: if request.resource.data.tenantId == tenantId;
      }

      // ── السائقون ──
      match /drivers/{driverId} {
        allow read, write: if request.auth != null && request.auth.uid == tenantId;
      }

      // ── العملاء ──
      match /customers/{customerId} {
        allow read, write: if request.auth != null && request.auth.uid == tenantId;
      }

      // ── المندوبون ──
      match /reps/{repId} {
        allow read, write: if request.auth != null && request.auth.uid == tenantId;
      }

      // ── المحفظة والمعاملات ──
      match /transactions/{txId} {
        allow read:  if request.auth != null && request.auth.uid == tenantId;
        allow write: if false; // تُكتب فقط من backend
      }
    }

    // ── الاشتراكات ──
    match /subscriptions/{tenantId} {
      // المستأجر يقرأ اشتراكه فقط
      allow read:  if request.auth != null && request.auth.uid == tenantId;
      // لا يعدّل الاشتراك بنفسه — يُعدّل فقط من Firebase Console أو Functions
      allow write: if false;
    }

    // ── رفض أي شيء آخر ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
